# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Anthropic API key from https://console.anthropic.com
# Required — used for @GTT Bot mention responses
ANTHROPIC_API_KEY=

# Absolute host path to your Obsidian vault
VAULT_PATH=/absolute/path/to/your/vault

# Models (must be pulled into the ollama container)
LLM_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text

# Qdrant
QDRANT_COLLECTION=vault

# Retrieval
TOP_K=5

# Minimum hybrid score (0–1) to use vault context in a response.
# Below this the bot answers from reasoning and flags the gap.
MIN_SCORE=0.45

# Weight given to keyword matching vs vector similarity (0–1).
# Higher = stronger boost for exact terms like DIF, RLR.
KEYWORD_WEIGHT=0.3

# Comma-separated Discord user IDs exempt from all cooldowns (e.g. mods, admins)
COOLDOWN_EXEMPT_USERS=

# Access control
# Comma-separated Discord guild (server) IDs the bot will respond in.
# Leave empty to allow all guilds (not recommended for public bots).
ALLOWED_GUILDS=

# Comma-separated Discord channel IDs the bot will respond in.
# Leave empty to allow all channels within allowed guilds.
ALLOWED_CHANNELS=

# Rate limiting
# Seconds between @mention responses per user (uses Anthropic API)
COOLDOWN_SECONDS=30

# Seconds between /knowledge-base searches per user (local, no API cost)
COOLDOWN_LOCAL_SECONDS=10

# Maximum question length in characters (prevents API cost abuse)
MAX_QUESTION_LENGTH=500

# Automod
# Channel ID for mod alerts
MOD_CHANNEL_ID=

# Channel ID for #general (self-promo detection)

# Comma-separated self-promo trigger phrases (kept private — not in source code)
# Example: follow me,subscribe,dm me,link in bio
SELF_PROMO_PATTERNS=
GENERAL_CHANNEL_ID=

# New account flag — accounts younger than this with no role posting long messages get flagged
NEW_ACCOUNT_DAYS=7

# Minimum message length to trigger the new account flag
SUSPICIOUS_MSG_LENGTH=200

# Number of bot-related messages to include in thread history (default: 30)
THREAD_HISTORY_LIMIT=30
