# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: Anthropic API key for Claude fallback on complex queries
# Leave empty to stay fully local (router will always use Ollama)
ANTHROPIC_API_KEY=

# Absolute host path to your Obsidian vault
VAULT_PATH=/absolute/path/to/your/vault

# Models (must be pulled into the ollama container)
LLM_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text

# Qdrant
QDRANT_COLLECTION=vault

# Retrieval
TOP_K=5

# Gmail integration (optional)
# 1. Create OAuth2 credentials at https://console.cloud.google.com (Desktop app type)
# 2. Download credentials.json, then run locally once to generate token.json:
#    GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json python -c "from email_reader import fetch_unread; fetch_unread()"
# 3. Set GOOGLE_CREDENTIALS_DIR to the directory containing both files
# 4. GOOGLE_CREDENTIALS_PATH inside the container is always /credentials/credentials.json
GOOGLE_CREDENTIALS_DIR=/absolute/path/to/credentials/dir
GOOGLE_CREDENTIALS_PATH=/credentials/credentials.json

# Your Discord user ID (Settings → Developer → Developer Mode ON → Close Settings → Right-click name → Copy User ID)
# If empty, !emails is disabled for everyone
DISCORD_EMAIL_ALLOWED_USER_IDS=
